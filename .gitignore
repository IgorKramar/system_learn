# OS
.DS_Store
Thumbs.db
*.swp
*~

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Sources: каталог в репозитории, файлы внутри (PDF и т.д.) — нет
Sources/*
!Sources/.gitkeep

# Obsidian: локальное состояние UI
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian: плагины — в git только manifest.json у каждого плагина
.obsidian/plugins/**/main.js
.obsidian/plugins/**/styles.css
.obsidian/plugins/**/data.json
.obsidian/plugins/**/*.lua
.obsidian/plugins/**/*.tex
.obsidian/plugins/**/*.sty
.obsidian/plugins/**/*.sh

# Obsidian: темы — без больших CSS (manifest остаётся)
.obsidian/themes/**/*.css
